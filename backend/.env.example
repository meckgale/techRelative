# MongoDB connection string
# Local (no auth): mongodb://localhost:27017/techrelative
# Docker (with auth): mongodb://admin:<password>@mongo:27017/techrelative?authSource=admin
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/techrelative
MONGO_URL=mongodb://localhost:27017/techrelative

# MongoDB credentials (used by docker-compose for mongo container init)
MONGO_USER=admin
MONGO_PASSWORD=

# Server port
PORT=3001

# Nginx proxy token (shared secret between Nginx and Express)
# Generate with: openssl rand -hex 32
# Leave empty to disable proxy auth (local development)
PROXY_TOKEN=

# CORS allowed origin (your domain in production)
# e.g. https://techrelative.yourdomain.com
CORS_ORIGIN=http://localhost
